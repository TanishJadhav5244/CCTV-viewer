{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/style\\.css",
      "dest": "/frontend/style.css"
    },
    {
      "src": "/app\\.js",
      "dest": "/frontend/app.js"
    },
    {
      "src": "/crops/(.*)",
      "dest": "/frontend/crops/$1"
    },
    {
      "src": "/(.*\\.(?:js|css|html|ico|png|svg|jpg|jpeg|woff2?))",
      "dest": "/frontend/$1"
    },
    {
      "src": "/(stats|sources|sessions|persons|detections|timeline|dashboard|heatmap|health|status|search|upload|process|stop|frame|api)(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
